# Cloudflare Pages headers — caching + security.

# ⚠️ STAGING ONLY — keep the *.pages.dev preview out of search indexes so it
# never competes with the live #1-ranked site. REMOVE this block at production cutover.
/*
  X-Robots-Tag: noindex, nofollow
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Long-cache fingerprint-safe static assets
/images/*
  Cache-Control: public, max-age=31536000, immutable
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
/favicon.ico
  Cache-Control: public, max-age=604800
