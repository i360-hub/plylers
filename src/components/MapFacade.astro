---
// Lightweight map "facade" for service-area pages.
// - Renders ZERO third-party weight on load (no Google iframe until the user clicks).
// - Primary action links to the Google Business Profile (the part with real local value).
// - On "Load interactive map", swaps in the official Google embed (TOS-compliant).
import business from '../data/business.json';
const {
  src,                                   // Google Maps embed URL (loaded on click)
  city,                                  // e.g. "Hot Springs, AR"
  gbpUrl = business.social.googleMaps,   // link to the Google Business Profile
  height = 360,
} = Astro.props;
const id = `map-${city.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
---
<div class="map-facade" style={`--map-h:${height}px`} data-src={src} id={id}>
  <div class="mf-bg" aria-hidden="true">
    <svg viewBox="0 0 48 48" class="mf-pin"><path fill="currentColor" d="M24 4a13 13 0 0 0-13 13c0 9 13 27 13 27s13-18 13-27A13 13 0 0 0 24 4z"/><circle cx="24" cy="17" r="5" fill="#fff"/></svg>
    <p class="mf-area">Serving {city}</p>
    <p class="mf-sub">Clark, Garland, Hot Spring, Pike &amp; Montgomery counties · 40-mile radius</p>
  </div>
  <div class="mf-actions">
    <a class="btn btn-green" href={gbpUrl} target="_blank" rel="noopener noreferrer">View us on Google →</a>
    <button class="btn btn-dark mf-load" type="button">Load interactive map</button>
  </div>
</div>
<script>
  document.querySelectorAll('.map-facade').forEach((el) => {
    const btn = el.querySelector('.mf-load');
    btn?.addEventListener('click', () => {
      const src = (el as HTMLElement).dataset.src;
      if (!src) return;
      const f = document.createElement('iframe');
      f.src = src;
      f.loading = 'lazy';
      f.title = el.id.replace('map-', 'Map of ').replace(/-/g, ' ');
      f.setAttribute('allowfullscreen', '');
      f.style.cssText = 'width:100%;height:100%;border:0;display:block;';
      el.replaceChildren(f);
      el.classList.add('mf-loaded');
    });
  });
</script>
<style>
  .map-facade {
    position: relative; border-radius: var(--radius-lg); overflow: hidden;
    border: 1px solid var(--line); box-shadow: var(--shadow); height: var(--map-h);
    background:
      linear-gradient(135deg, rgba(46,125,70,0.10), rgba(20,54,31,0.16)),
      repeating-linear-gradient(0deg, var(--green-50), var(--green-50) 22px, #eef5f0 22px, #eef5f0 23px),
      repeating-linear-gradient(90deg, var(--green-50), var(--green-50) 22px, #eef5f0 22px, #eef5f0 23px);
    display: grid; place-items: center;
  }
  .map-facade.mf-loaded { display: block; }
  .mf-bg { text-align: center; padding: 1.5rem; color: var(--green-800); }
  .mf-pin { width: 46px; height: 46px; color: var(--green-600); filter: drop-shadow(0 3px 5px rgba(20,54,31,.25)); }
  .mf-area { font-family: var(--font-heading); font-weight: 800; font-size: 1.4rem; color: var(--ink); margin: 0.4rem 0 0.2rem; }
  .mf-sub { font-size: 0.9rem; color: var(--muted); margin: 0; max-width: 460px; }
  .mf-actions { position: absolute; left: 0; right: 0; bottom: 0; display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; padding: 1rem; background: linear-gradient(to top, rgba(255,255,255,0.96), rgba(255,255,255,0)); }
  .mf-actions .btn { padding: 0.6rem 1.1rem; font-size: 0.95rem; }
  @media (max-width: 480px) { .mf-actions .btn { flex: 1; justify-content: center; } }
</style>
