---
// Visual breadcrumb trail. Pair with breadcrumb() schema in the page.
export interface Props { items: { name: string; path: string }[]; }
const { items } = Astro.props;
---
<nav class="breadcrumbs" aria-label="Breadcrumb">
  <div class="container">
    <ol>
      {items.map((it, i) => (
        <li>
          {i < items.length - 1 ? <a href={it.path}>{it.name}</a> : <span aria-current="page">{it.name}</span>}
          {i < items.length - 1 && <span class="sep" aria-hidden="true">›</span>}
        </li>
      ))}
    </ol>
  </div>
</nav>
<style>
  .breadcrumbs { background: var(--bg-alt); border-bottom: 1px solid var(--line); font-size: 0.88rem; }
  .breadcrumbs ol { list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem; margin: 0; padding: 0.7rem 0; }
  .breadcrumbs li { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--muted); }
  .breadcrumbs a { color: var(--green-700); }
  .breadcrumbs .sep { color: var(--muted); }
</style>
