---
import business from '../data/business.json';
import areas from '../data/areas.json';

const services = [
  { name: 'Tree Removal', href: '/tree-removal' },
  { name: 'Tree Trimming', href: '/tree-trimming' },
  { name: 'Stump Grinding', href: '/stump-grinding' },
  { name: 'Emergency Storm Damage', href: '/emergency-storm-damage' },
];
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (h: string) => (h === '/' ? path === '/' : path === h);
---

<header class="site-header">
  <div class="topbar">
    <div class="container topbar-inner">
      <span class="topbar-note">Locally owned in Arkadelphia since 2002 · Free estimates · Licensed &amp; insured</span>
      <a class="topbar-phone" href={`tel:${business.phoneHref}`}>Call {business.phoneDisplay}</a>
    </div>
  </div>
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label={`${business.name} — home`}>
      <img src="/images/plylers-tree-service-logo.png" width="190" height="48" alt={`${business.name} logo`} class="brand-logo" />
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="primary-nav" aria-label="Primary">
      <ul class="nav-list">
        <li><a href="/" aria-current={isActive('/') ? 'page' : undefined}>Home</a></li>
        <li class="has-menu">
          <button type="button" class="menu-btn" aria-expanded="false">Services <span class="caret">▾</span></button>
          <ul class="submenu">
            {services.map((s) => <li><a href={s.href} aria-current={isActive(s.href) ? 'page' : undefined}>{s.name}</a></li>)}
          </ul>
        </li>
        <li class="has-menu">
          <button type="button" class="menu-btn" aria-expanded="false">Service Areas <span class="caret">▾</span></button>
          <ul class="submenu">
            <li><a href="/service-areas"><strong>All Service Areas</strong></a></li>
            {areas.hubs.map((h) => <li><a href={h.slug} aria-current={isActive(h.slug) ? 'page' : undefined}>{h.city}</a></li>)}
          </ul>
        </li>
        <li><a href="/about" aria-current={isActive('/about') ? 'page' : undefined}>About</a></li>
        <li><a href="/reviews" aria-current={isActive('/reviews') ? 'page' : undefined}>Reviews</a></li>
        <li><a href="/gallery" aria-current={isActive('/gallery') ? 'page' : undefined}>Gallery</a></li>
        <li><a href="/blog" aria-current={isActive('/blog') ? 'page' : undefined}>Blog</a></li>
        <li><a href="/contact" aria-current={isActive('/contact') ? 'page' : undefined}>Contact</a></li>
        <li class="nav-cta"><a class="btn btn-primary" href="/contact">Get a Free Quote</a></li>
      </ul>
    </nav>
  </div>
</header>

<script>
  // Progressive enhancement: tap/click toggles submenu + aria-expanded on touch/desktop.
  // Mobile drawer shows submenus open by default (CSS); this adds correct semantics.
  document.querySelectorAll('.menu-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const li = btn.closest('.has-menu');
      const open = li?.classList.toggle('open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      e.preventDefault();
    });
  });
  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (!t.closest('.has-menu')) {
      document.querySelectorAll('.has-menu.open').forEach((li) => {
        li.classList.remove('open');
        li.querySelector('.menu-btn')?.setAttribute('aria-expanded', 'false');
      });
    }
  });
  // Close mobile drawer after navigating
  document.querySelectorAll('.primary-nav a').forEach((a) => {
    a.addEventListener('click', () => {
      const t = document.getElementById('nav-toggle') as HTMLInputElement | null;
      if (t) t.checked = false;
    });
  });
</script>

<style>
  .site-header { position: sticky; top: 0; z-index: 100; background: #fff; box-shadow: 0 1px 0 var(--line); }
  .topbar { background: var(--green-900); color: #cfe0d6; font-size: 0.85rem; }
  .topbar-inner { display: flex; justify-content: space-between; align-items: center; gap: 1rem; padding-block: 0.45rem; }
  .topbar-note { opacity: 0.92; }
  .topbar-phone { color: #fff; font-weight: 700; }
  .topbar-phone:hover { color: var(--amber-500); text-decoration: none; }

  .nav-inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding-block: 0.6rem; }
  .brand-logo { height: 48px; width: auto; }
  .primary-nav .nav-list { list-style: none; display: flex; align-items: center; gap: 0.25rem; margin: 0; padding: 0; }
  .nav-list > li > a, .menu-btn {
    display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.5rem 0.7rem; border-radius: 8px;
    color: var(--ink); font-weight: 600; font-size: 0.97rem; background: none; border: 0; cursor: pointer; font-family: inherit;
  }
  .nav-list > li > a:hover, .menu-btn:hover { background: var(--green-50); text-decoration: none; }
  .nav-list a[aria-current="page"] { color: var(--green-700); }
  .has-menu { position: relative; }
  .submenu {
    list-style: none; margin: 0; padding: 0.4rem; position: absolute; top: 100%; left: 0; min-width: 230px;
    background: #fff; border: 1px solid var(--line); border-radius: 12px; box-shadow: var(--shadow-lg);
    opacity: 0; visibility: hidden; transform: translateY(6px); transition: all .15s ease;
  }
  .has-menu:hover .submenu, .has-menu:focus-within .submenu, .has-menu.open .submenu { opacity: 1; visibility: visible; transform: translateY(0); }
  .submenu a { display: block; padding: 0.55rem 0.8rem; border-radius: 8px; color: var(--body); font-weight: 500; }
  .submenu a:hover { background: var(--green-50); color: var(--green-800); text-decoration: none; }
  .nav-cta a { padding: 0.6rem 1.1rem; }

  .nav-toggle, .nav-burger { display: none; }
  .nav-burger span { display: block; width: 26px; height: 3px; background: var(--green-900); margin: 5px 0; border-radius: 2px; transition: .2s; }

  @media (max-width: 960px) {
    .nav-burger { display: block; cursor: pointer; padding: 6px; }
    .primary-nav {
      position: fixed; inset: 0 0 0 auto; width: min(82vw, 340px); background: #fff; padding: 5rem 1.25rem 2rem;
      transform: translateX(100%); transition: transform .25s ease; box-shadow: var(--shadow-lg); overflow-y: auto;
    }
    .nav-toggle:checked ~ .primary-nav { transform: translateX(0); }
    .nav-list { flex-direction: column; align-items: stretch; gap: 0.15rem; }
    .nav-list > li > a, .menu-btn { width: 100%; font-size: 1.05rem; }
    .has-menu .submenu {
      position: static; opacity: 1; visibility: visible; transform: none; box-shadow: none; border: 0; border-left: 2px solid var(--green-100);
      border-radius: 0; margin-left: 0.6rem; padding-left: 0.4rem;
    }
    .nav-cta { margin-top: 0.6rem; }
    .nav-cta a { width: 100%; justify-content: center; }
    .topbar-note { display: none; }
    .topbar-inner { justify-content: center; }
  }
</style>
