---
import business from '../data/business.json';
export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;        // /images/... path
  imageAlt?: string;
  primaryCta?: { label: string; href: string };
  showPhone?: boolean;
  compact?: boolean;
}
const {
  eyebrow,
  title,
  subtitle,
  image,
  imageAlt = '',
  primaryCta = { label: 'Get a Free Estimate', href: '/contact' },
  showPhone = true,
  compact = false,
} = Astro.props;
---
<section class={`hero ${compact ? 'hero-compact' : ''} ${image ? 'hero-has-img' : ''}`}>
  <div class="container hero-grid">
    <div class="hero-copy">
      {eyebrow && <p class="eyebrow hero-eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      {subtitle && <p class="lead hero-sub">{subtitle}</p>}
      <div class="hero-cta">
        <a class="btn btn-primary btn-lg" href={primaryCta.href}>{primaryCta.label}</a>
        {showPhone && <a class="btn btn-ghost btn-lg hero-call" href={`tel:${business.phoneHref}`}>Call {business.phoneDisplay}</a>}
      </div>
      <p class="hero-trust">★★★★★ <strong>{business.rating.value}</strong> · {business.rating.count}+ Google reviews · Licensed &amp; insured · Free estimates</p>
    </div>
    {image && (
      <div class="hero-media">
        <img src={image} alt={imageAlt} width="640" height="480" fetchpriority="high" decoding="async" />
      </div>
    )}
  </div>
</section>
<style>
  .hero { background: linear-gradient(160deg, var(--green-900), var(--green-800) 60%, var(--green-700)); color: #e7f0ea; padding-block: clamp(3rem, 7vw, 5.5rem); }
  .hero-grid { display: grid; gap: 2.5rem; align-items: center; grid-template-columns: 1.1fr 0.9fr; }
  .hero-has-img .hero-copy { max-width: none; }
  .hero:not(.hero-has-img) .hero-grid { grid-template-columns: 1fr; }
  .hero:not(.hero-has-img) .hero-copy { max-width: 820px; }
  .hero h1 { color: #fff; }
  .hero-eyebrow { color: var(--amber-500); }
  .hero-sub { color: #d3e2d8; font-size: 1.2rem; max-width: 560px; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 0.8rem; margin: 1.6rem 0 1rem; }
  .hero-call { color:#fff; }
  .hero-trust { font-size: 0.92rem; color: #c0d4c7; margin: 0; }
  .hero-trust strong { color: var(--amber-500); }
  .hero-media img { border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); width: 100%; height: auto; aspect-ratio: 4 / 3; object-fit: cover; }
  .hero-compact { padding-block: clamp(2.2rem, 5vw, 3.4rem); }
  @media (max-width: 820px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-media { order: -1; }
  }
</style>
