---
import business from '../data/business.json';
---
<a class="emergency-banner" href={`tel:${business.phoneHref}`} aria-label={`Same-day emergency response — call ${business.phoneDisplay}`}>
  <svg class="eb-bolt" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 2L4.5 13.5H11l-1 8.5L19.5 10H13z"/></svg>
  <span><strong>Same-Day Emergency Response</strong> — Call {business.phoneDisplay} Right Now</span>
</a>
<style>
  .emergency-banner {
    display: flex; align-items: center; justify-content: center; gap: 0.7rem;
    width: 100%; padding: 0.9rem 1.25rem; text-align: center;
    background: var(--amber-500); color: var(--green-900); font-weight: 700;
    font-size: clamp(1rem, 2.2vw, 1.18rem); line-height: 1.3;
    border: 0; text-decoration: none; transition: background .15s ease;
  }
  .emergency-banner:hover { background: var(--amber-600); text-decoration: none; }
  .emergency-banner .eb-bolt { width: 22px; height: 22px; flex: none; }
  .emergency-banner strong { font-weight: 800; }
  @media (max-width: 480px) { .emergency-banner { font-size: 0.98rem; } }
</style>
