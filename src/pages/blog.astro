---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CtaBand from '../components/CtaBand.astro';
import { breadcrumb, SITE, ORG_ID, WEBSITE_ID, LOCALBUSINESS_ID } from '../lib/schema';
import { getPublishedPosts } from '../lib/posts';

const title = "Tree Care Tips & Guides | Plyler's Tree Service Blog";
const description =
  "Expert tree care advice from a 24-year Arkadelphia arborist — when to remove a tree, storm prep, trimming vs removal, hiring tips & more.";
const path = '/blog';
const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Blog', path },
];

// Posts live at ROOT-level slugs (e.g. /signs-tree-is-dying), not under /blog/.
// Future-dated posts stay off the hub (and out of its Blog schema) until published.
const posts = await getPublishedPosts();

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const schema = [
  {
    '@type': 'CollectionPage',
    '@id': `${SITE}${path}#webpage`,
    url: `${SITE}${path}`,
    name: title,
    description,
    isPartOf: { '@id': WEBSITE_ID },
    about: { '@id': LOCALBUSINESS_ID },
    publisher: { '@id': ORG_ID },
    breadcrumb: { '@id': `${SITE}${path}#breadcrumb` },
  },
  { ...breadcrumb(crumbs), '@id': `${SITE}${path}#breadcrumb` },
  {
    '@type': 'Blog',
    '@id': `${SITE}${path}#blog`,
    name: title,
    description,
    publisher: { '@id': ORG_ID },
    blogPost: posts.map((p) => ({
      '@type': 'BlogPosting',
      '@id': `${SITE}/${p.id}#blogposting`,
      headline: p.data.title,
      description: p.data.description,
      datePublished: p.data.pubDate.toISOString(),
      dateModified: (p.data.updatedDate ?? p.data.pubDate).toISOString(),
      url: `${SITE}/${p.id}`,
      author: { '@type': 'Person', name: p.data.author },
    })),
  },
];
---
<BaseLayout title={title} description={description} path={path} schema={schema}>
  <Breadcrumbs items={crumbs} />

  <section class="section">
    <div class="container">
      <header class="blog-head measure">
        <p class="eyebrow">Plyler's Tree Service</p>
        <h1>Tree Care Tips & Local Guides</h1>
        <p class="lead">
          Straight, plainspoken advice from Robbie Plyler and our crew — 24 years of tree work
          in Arkadelphia, Clark County, and across southwest Arkansas. When to remove a tree,
          how to handle a storm-downed tree, trimming vs removal, and what to ask before you
          hire anyone.
        </p>
      </header>

      <div class="blog-grid">
        {posts.map((p) => (
          <article class="blog-card card">
            <a class="thumb" href={`/${p.id}`} aria-label={p.data.title}>
              <img
                src={p.data.heroImage}
                alt={p.data.heroAlt}
                width="640"
                height="360"
                loading="lazy"
                decoding="async"
              />
            </a>
            <div class="blog-card-body">
              <h2><a href={`/${p.id}`}>{p.data.title}</a></h2>
              <p class="date">
                <time datetime={p.data.pubDate.toISOString()}>
                  {dateFmt.format(p.data.pubDate)}
                </time>
              </p>
              <p class="desc">{p.data.description}</p>
              <p class="more"><a href={`/${p.id}`}>Read more →</a></p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>

<style>
  .blog-head { margin-bottom: 2.6rem; }
  .blog-head h1 { margin: 0.3rem 0 0.8rem; }
  .blog-grid {
    display: grid;
    gap: 1.6rem;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }
  .blog-card { display: flex; flex-direction: column; padding: 0; overflow: hidden; }
  .blog-card .thumb { display: block; }
  .blog-card .thumb img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }
  .blog-card-body { padding: 1.4rem 1.5rem 1.6rem; display: flex; flex-direction: column; flex: 1; }
  .blog-card h2 { font-size: 1.2rem; line-height: 1.3; margin: 0 0 0.4rem; }
  .blog-card h2 a { color: var(--ink); }
  .blog-card h2 a:hover { color: var(--green-700); }
  .blog-card .date { color: var(--muted); font-size: 0.85rem; margin: 0 0 0.7rem; }
  .blog-card .desc { color: var(--muted); margin: 0 0 1rem; flex: 1; }
  .blog-card .more { margin: 0; }
  .blog-card .more a { color: var(--green-700); font-weight: 600; }
</style>
